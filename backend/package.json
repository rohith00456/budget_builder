{
    "name": "financial-budget-builder-backend",
    "version": "1.0.0",
    "description": "AI-powered Financial Budget Builder Backend",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc && prisma generate",
        "start": "node dist/server.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "lint": "eslint src --ext .ts",
        "postinstall": "prisma generate",
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.24.0",
        "@aws-sdk/client-s3": "^3.600.0",
        "@google/generative-ai": "^0.15.0",
        "@prisma/client": "^5.16.0",
        "axios": "^1.7.0",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "exceljs": "^4.4.0",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "form-data": "^4.0.0",
        "groq-sdk": "^0.5.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "pdfkit": "^0.15.0",
        "pptxgenjs": "^4.0.1",
        "redis": "^4.6.14",
        "socket.io": "^4.7.5",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.14.0",
        "@types/node-cron": "^3.0.11",
        "@types/pdfkit": "^0.13.4",
        "prisma": "^5.16.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}